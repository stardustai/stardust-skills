{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stardust.ai/schemas/vibe-coding/task-feedback.schema.json",
  "title": "Loop Engineering Task Feedback Contract",
  "description": "Binds one task to the current commit, environment, observable signals, executable checks, and evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "current_commit", "environment", "business_goal_refs", "target", "observable_signals", "baseline", "pass_fail_rules", "verification_commands", "evidence_paths", "rollback_method"],
  "properties": {
    "$schema": {"type": "string", "minLength": 1},
    "schema_version": {"const": "1.0"},
    "task_id": {"type": "string", "minLength": 1},
    "current_commit": {"type": "string", "minLength": 1},
    "environment": {"type": "string", "minLength": 1},
    "business_goal_refs": {"$ref": "#/$defs/non_empty_strings"},
    "target": {"type": "string", "minLength": 1},
    "observable_signals": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["signal_id", "source", "expected"],
        "properties": {
          "signal_id": {"type": "string", "minLength": 1},
          "source": {"type": "string", "minLength": 1},
          "expected": {"type": ["string", "number", "boolean"]}
        }
      }
    },
    "baseline": {
      "type": "object", "additionalProperties": false,
      "required": ["measured_at", "commit", "environment", "evidence_paths"],
      "properties": {
        "measured_at": {"type": "string", "format": "date-time"},
        "commit": {"type": "string", "minLength": 1},
        "environment": {"type": "string", "minLength": 1},
        "evidence_paths": {"$ref": "#/$defs/non_empty_strings"}
      }
    },
    "pass_fail_rules": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["rule_id", "signal_id", "operator", "expected"],
        "properties": {
          "rule_id": {"type": "string", "minLength": 1},
          "signal_id": {"type": "string", "minLength": 1},
          "operator": {"enum": ["equals", "not_equals", "less_than", "less_than_or_equal", "greater_than", "greater_than_or_equal", "contains"]},
          "expected": {"type": ["string", "number", "boolean"]}
        }
      }
    },
    "verification_commands": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/command"}},
    "evidence_paths": {"$ref": "#/$defs/non_empty_strings"},
    "rollback_method": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "non_empty_strings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "command": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
