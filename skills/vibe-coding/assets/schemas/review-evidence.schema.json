{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stardust.ai/schemas/vibe-coding/review-evidence.schema.json",
  "title": "Independent Review Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "commit", "author_agent_id", "status", "reviews", "independent_verification", "runtime_evidence", "attestation", "reviewed_at", "pull_request_url"],
  "properties": {
    "$schema": {"type": "string", "minLength": 1},
    "schema_version": {"const": "1.0"},
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "author_agent_id": {"type": "string", "minLength": 1},
    "status": {"const": "pass"},
    "reviews": {
      "type": "array", "minItems": 3,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["review_type", "reviewer_id", "execution_context_id", "reviewed_artifacts", "status", "findings_count", "blocking_findings", "evidence_uri"],
        "properties": {
          "review_type": {"enum": ["spec", "code_quality", "independent_test"]},
          "reviewer_id": {"type": "string", "minLength": 1},
          "execution_context_id": {"type": "string", "minLength": 1},
          "reviewed_artifacts": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "status": {"const": "pass"},
          "findings_count": {"type": "integer", "minimum": 0},
          "blocking_findings": {"const": 0},
          "evidence_uri": {"type": "string", "minLength": 1}
        }
      }
    },
    "independent_verification": {
      "type": "object", "additionalProperties": false,
      "required": ["commit", "checks"],
      "properties": {
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "checks": {
          "type": "array", "minItems": 2,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["name", "command", "exit_code", "captured_at", "evidence_manifest", "evidence_sha256"],
            "properties": {
              "name": {"enum": ["test_full", "eval_full"]},
              "command": {"$ref": "#/$defs/command"},
              "exit_code": {"const": 0},
              "captured_at": {"type": "string", "format": "date-time"},
              "evidence_manifest": {"type": "string", "minLength": 1},
              "evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }
          }
        }
      }
    },
    "runtime_evidence": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/runtimeObservation"}},
    "attestation": {
      "type": "object", "additionalProperties": false,
      "required": ["provider", "run_id", "artifact_uri"],
      "properties": {
        "provider": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "artifact_uri": {"type": "string", "minLength": 1}
      }
    },
    "reviewed_at": {"type": "string", "format": "date-time"},
    "pull_request_url": {"type": ["string", "null"], "format": "uri"}
  },
  "$defs": {
    "command": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "runtimeObservation": {
      "type": "object", "additionalProperties": false,
      "required": ["check_name", "evidence_manifest", "evidence_sha256", "observed"],
      "properties": {
        "check_name": {"type": "string", "minLength": 1},
        "evidence_manifest": {"type": "string", "minLength": 1},
        "evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "observed": {"type": ["string", "number", "boolean", "object", "array"]}
      }
    }
  }
}
