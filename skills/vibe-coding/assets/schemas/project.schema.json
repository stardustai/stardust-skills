{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stardust.ai/schemas/vibe-coding/project.schema.json",
  "title": "Vibe Coding PROJECT.yaml",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project_id", "name", "status", "repository", "artifacts", "risk", "owners", "commands", "command_timeouts_seconds", "verification", "features", "technical_debt", "pre_commit", "delivery", "deployment"],
  "properties": {
    "$schema": {"type": "string", "minLength": 1},
    "schema_version": {"const": "1.0"},
    "project_id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "status": {"type": "string", "minLength": 1},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["remote_url", "default_branch", "feature_branch", "baseline_commit", "last_green_commit", "working_tree", "known_dirty_paths"],
      "properties": {
        "remote_url": {"type": "string", "format": "uri"},
        "default_branch": {"type": "string", "minLength": 1},
        "feature_branch": {"type": "string", "minLength": 1},
        "baseline_commit": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
        "last_green_commit": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
        "working_tree": {"enum": ["clean", "known_dirty"]},
        "known_dirty_paths": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spec", "spec_sha256", "design", "plan"],
      "properties": {
        "spec": {"type": "string", "minLength": 1},
        "spec_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "design": {"type": "string", "minLength": 1},
        "plan": {"type": "string", "minLength": 1}
      }
    },
    "risk": {
      "type": "object", "additionalProperties": false, "required": ["tier", "source"],
      "properties": {"tier": {"enum": ["R0", "R1", "R2", "R3"]}, "source": {"type": "string", "minLength": 1}}
    },
    "owners": {
      "type": "object", "additionalProperties": false,
      "required": ["business", "product", "engineering", "qa", "decision"],
      "properties": {
        "business": {"type": "string", "minLength": 1}, "product": {"type": "string", "minLength": 1},
        "engineering": {"type": "string", "minLength": 1}, "qa": {"type": "string", "minLength": 1},
        "decision": {"type": "string", "minLength": 1}
      }
    },
    "commands": {
      "type": "object", "additionalProperties": {"$ref": "#/$defs/command"},
      "required": ["install", "start", "stop", "build", "pre_commit_full", "test_full", "eval_full", "smoke", "health_check"],
      "properties": {
        "install": {"$ref": "#/$defs/command"}, "start": {"$ref": "#/$defs/command"},
        "stop": {"$ref": "#/$defs/command"}, "build": {"$ref": "#/$defs/command"},
        "pre_commit_full": {"$ref": "#/$defs/command"}, "test_full": {"$ref": "#/$defs/command"},
        "eval_full": {"$ref": "#/$defs/command"}, "smoke": {"$ref": "#/$defs/command"},
        "health_check": {"$ref": "#/$defs/command"}
      }
    },
    "command_timeouts_seconds": {
      "type": "object", "additionalProperties": {"type": "number", "exclusiveMinimum": 0},
      "required": ["default", "install", "start", "stop", "build", "pre_commit_full", "test_full", "eval_full", "smoke", "health_check"],
      "properties": {
        "default": {"type": "number", "exclusiveMinimum": 0}, "install": {"type": "number", "exclusiveMinimum": 0},
        "start": {"type": "number", "exclusiveMinimum": 0}, "stop": {"type": "number", "exclusiveMinimum": 0},
        "build": {"type": "number", "exclusiveMinimum": 0}, "pre_commit_full": {"type": "number", "exclusiveMinimum": 0},
        "test_full": {"type": "number", "exclusiveMinimum": 0}, "eval_full": {"type": "number", "exclusiveMinimum": 0},
        "smoke": {"type": "number", "exclusiveMinimum": 0}, "health_check": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "verification": {
      "type": "object", "additionalProperties": false,
      "required": ["check_inventory", "runtime", "business", "applicability"],
      "properties": {
        "check_inventory": {"type": "array", "minItems": 3, "uniqueItems": true, "contains": {"const": "test_full"}, "items": {"type": "string", "minLength": 1}},
        "runtime": {"$ref": "#/$defs/evidencePolicy"},
        "business": {"$ref": "#/$defs/evidencePolicy"},
        "applicability": {
          "type": "object", "additionalProperties": false,
          "required": ["format_static_type", "unit", "integration", "business_e2e", "permissions", "ui_accessibility", "performance_cost", "recovery_rollback", "eval"],
          "properties": {
            "format_static_type": {"$ref": "#/$defs/applicabilityPolicy"},
            "unit": {"$ref": "#/$defs/applicabilityPolicy"},
            "integration": {"$ref": "#/$defs/applicabilityPolicy"},
            "business_e2e": {"$ref": "#/$defs/applicabilityPolicy"},
            "permissions": {"$ref": "#/$defs/applicabilityPolicy"},
            "ui_accessibility": {"$ref": "#/$defs/applicabilityPolicy"},
            "performance_cost": {"$ref": "#/$defs/applicabilityPolicy"},
            "recovery_rollback": {"$ref": "#/$defs/applicabilityPolicy"},
            "eval": {"$ref": "#/$defs/applicabilityPolicy"}
          }
        }
      }
    },
    "features": {
      "type": "object", "additionalProperties": false, "required": ["algorithmic", "business_ui"],
      "properties": {"algorithmic": {"type": "boolean"}, "business_ui": {"type": "boolean"}}
    },
    "technical_debt": {
      "type": "object", "additionalProperties": false,
      "required": ["strategy", "approved_by", "decision_record", "excluded_debt_ids", "excluded_paths"],
      "properties": {
        "strategy": {"enum": ["full_remediation", "minimum_safe"]}, "approved_by": {"type": "string", "minLength": 1},
        "decision_record": {"type": "string", "minLength": 1},
        "excluded_debt_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "excluded_paths": {"type": "array", "items": {"type": "string", "minLength": 1}}
      },
      "allOf": [
        {"if": {"properties": {"strategy": {"const": "minimum_safe"}}}, "then": {"properties": {"excluded_debt_ids": {"minItems": 1}, "excluded_paths": {"minItems": 1}}}},
        {"if": {"properties": {"strategy": {"const": "full_remediation"}}}, "then": {"properties": {"excluded_debt_ids": {"maxItems": 0}, "excluded_paths": {"maxItems": 0}}}}
      ]
    },
    "pre_commit": {
      "type": "object", "additionalProperties": false, "required": ["hook_path", "full_suite"],
      "properties": {"hook_path": {"const": ".githooks/pre-commit"}, "full_suite": {"const": true}}
    },
    "delivery": {
      "type": "object", "additionalProperties": false,
      "required": ["collaboration", "change_size", "direct_push_permitted", "explicit_pr_required", "change_dimensions", "mode", "requires_pr"],
      "properties": {
        "collaboration": {"enum": ["single_owner", "multi_person"]}, "change_size": {"enum": ["small", "large"]},
        "direct_push_permitted": {"type": "boolean"}, "explicit_pr_required": {"type": "boolean"},
        "change_dimensions": {
          "type": "object", "additionalProperties": false,
          "required": ["architecture", "public_api", "data_schema", "permissions", "dependency_or_integration", "migration_or_bulk_write", "technical_debt_or_refactor", "material_spec_or_plan", "critical_runtime"],
          "properties": {
            "architecture": {"type": "boolean"}, "public_api": {"type": "boolean"}, "data_schema": {"type": "boolean"},
            "permissions": {"type": "boolean"}, "dependency_or_integration": {"type": "boolean"},
            "migration_or_bulk_write": {"type": "boolean"}, "technical_debt_or_refactor": {"type": "boolean"},
            "material_spec_or_plan": {"type": "boolean"}, "critical_runtime": {"type": "boolean"}
          }
        },
        "mode": {"enum": ["direct_push", "pull_request"]}, "requires_pr": {"type": "boolean"}
      }
    },
    "deployment": {
      "type": "object", "additionalProperties": false,
      "required": ["required", "sre_skill", "target_environment", "lifecycle_status"],
      "properties": {
        "required": {"type": "boolean"}, "sre_skill": {"const": "production-devops-sre"},
        "target_environment": {"type": ["string", "null"]},
        "lifecycle_status": {"enum": ["not_started", "blocked", "non_production_deployed", "production_rollout", "production_deployed", "rolled_back"]}
      }
    }
  },
  "$defs": {
    "command": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "evidencePolicy": {
      "type": "object", "additionalProperties": false, "required": ["check_names", "required_evidence_fields"],
      "properties": {
        "check_names": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "required_evidence_fields": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "applicabilityPolicy": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "reason", "evidence", "approved_by"],
      "properties": {
        "status": {"enum": ["required", "not_applicable"]},
        "reason": {"type": "string", "minLength": 1},
        "evidence": {"type": "string", "minLength": 1},
        "approved_by": {"type": "string", "minLength": 1}
      }
    }
  }
}
