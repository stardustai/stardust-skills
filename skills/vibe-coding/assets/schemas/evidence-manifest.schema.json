{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stardust.ai/schemas/vibe-coding/evidence-manifest.schema.json",
  "title": "Bounded Project Check Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "phase", "project_root", "git", "started_at", "finished_at", "checks"],
  "properties": {
    "$schema": {"type": "string", "minLength": 1},
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "phase": {"enum": ["pre_commit", "full"]},
    "project_root": {"type": "string", "minLength": 1},
    "git": {
      "type": "object", "additionalProperties": false,
      "required": ["commit", "branch", "clean"],
      "properties": {
        "commit": {"type": ["string", "null"], "pattern": "^[0-9a-fA-F]{40}$"},
        "branch": {"type": ["string", "null"]},
        "clean": {"type": ["boolean", "null"]}
      }
    },
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": ["string", "null"], "format": "date-time"},
    "checks": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["name", "command", "timeout_seconds", "started_at", "finished_at", "status", "exit_code", "stdout", "stderr"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "command": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "timeout_seconds": {"type": "number", "exclusiveMinimum": 0},
          "started_at": {"type": "string", "format": "date-time"},
          "finished_at": {"type": ["string", "null"], "format": "date-time"},
          "status": {"enum": ["passed", "failed", "timed_out", "start_failed", null]},
          "exit_code": {"type": ["integer", "null"]},
          "error_type": {"type": "string", "minLength": 1},
          "stdout": {"$ref": "#/$defs/outputSummary"},
          "stderr": {"$ref": "#/$defs/outputSummary"}
        }
      }
    }
  },
  "$defs": {
    "outputSummary": {
      "type": "object", "additionalProperties": false,
      "required": ["byte_count", "sha256", "summary"],
      "properties": {
        "byte_count": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "summary": {"type": "string", "minLength": 1}
      }
    }
  }
}
