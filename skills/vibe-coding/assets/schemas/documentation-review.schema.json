{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stardust.ai/schemas/vibe-coding/documentation-review.schema.json",
  "title": "Vibe Coding independent documentation content review",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "author_agent_id", "author_execution_context_id", "reviewer_id", "execution_context_id", "reviewed_at", "status", "documents"],
  "properties": {
    "$schema": {"type": "string", "minLength": 1},
    "schema_version": {"const": "1.0"},
    "author_agent_id": {"type": "string", "minLength": 1},
    "author_execution_context_id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "reviewer_id": {"type": "string", "minLength": 1},
    "execution_context_id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "reviewed_at": {"type": "string", "format": "date-time"},
    "status": {"const": "pass"},
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["responsibility", "path", "sha256", "coverage"],
        "properties": {
          "responsibility": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "coverage": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["topic", "locator", "section_sha256"],
              "properties": {
                "topic": {"type": "string", "minLength": 1},
                "locator": {"type": "string", "minLength": 3},
                "section_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
              }
            }
          }
        }
      }
    }
  }
}
