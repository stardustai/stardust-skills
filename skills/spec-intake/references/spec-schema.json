{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spec Driven Intake Schema",
  "type": "object",
  "required": [
    "spec_version",
    "spec_id",
    "title",
    "status",
    "priority",
    "intake_stage",
    "commercial_context",
    "handoff_options",
    "product_context",
    "spec_type",
    "owners",
    "business_context",
    "business_objects",
    "scope",
    "input_materials",
    "workflow",
    "domain_pack_context",
    "priority_decision",
    "ui_requirements",
    "capability_boundaries",
    "evidence_requirements",
    "data_governance",
    "acceptance_standards",
    "testing_standards",
    "operation_standards",
    "review_gates",
    "missing_fields",
    "readiness_label"
  ],
  "additionalProperties": false,
  "properties": {
    "spec_version": { "type": "string" },
    "spec_id": { "type": "string" },
    "title": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "spec_review",
        "ready_for_engineering",
        "in_development",
        "qa_gate",
        "devops_gate",
        "business_acceptance",
        "launched",
        "rejected",
        "archived"
      ]
    },
    "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "unknown"] },
    "intake_stage": {
      "type": "string",
      "enum": [
        "business_feasibility",
        "product_shape",
        "technical_spec",
        "unknown"
      ]
    },
    "handoff_options": {
      "type": "object",
      "required": [
        "current_gate",
        "available_next_actions",
        "selected_next_action",
        "handoff_target",
        "handoff_notes"
      ],
      "properties": {
        "current_gate": {
          "type": "string",
          "enum": [
            "business_to_product",
            "product_to_technology",
            "technology_to_delivery",
            "continue_intake",
            "unknown"
          ]
        },
        "available_next_actions": { "type": "array" },
        "selected_next_action": {
          "type": "string",
          "enum": [
            "handoff_to_product",
            "continue_product_shape",
            "handoff_to_technology",
            "continue_technical_spec",
            "stop",
            "unknown"
          ]
        },
        "handoff_target": { "type": ["string", "null"] },
        "handoff_notes": { "type": "array" }
      }
    },
    "product_context": {
      "type": "object",
      "required": [
        "build_target",
        "company_product",
        "product_assumptions",
        "product_open_questions"
      ],
      "properties": {
        "build_target": {
          "type": "string",
          "enum": [
            "friday_agent",
            "domain_pack",
            "friday_memory",
            "morningstar",
            "internal_tool",
            "standalone_product",
            "demo",
            "unknown"
          ]
        },
        "company_product": { "type": ["string", "null"] },
        "product_assumptions": { "type": "array" },
        "product_open_questions": { "type": "array" }
      }
    },
    "spec_type": {
      "type": "string",
      "enum": [
        "customer_poc",
        "domain_pack",
        "product_feature",
        "internal_tool",
        "data_project",
        "automation",
        "platform_capability"
      ]
    },
    "product_line": { "type": ["string", "null"] },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "owners": {
      "type": "object",
      "required": [
        "business_owner",
        "product_owner",
        "engineering_owner",
        "qa_owner",
        "devops_owner",
        "compliance_owner",
        "decision_owner"
      ],
      "properties": {
        "business_owner": { "type": ["string", "null"] },
        "product_owner": { "type": ["string", "null"] },
        "engineering_owner": { "type": ["string", "null"] },
        "qa_owner": { "type": ["string", "null"] },
        "devops_owner": { "type": ["string", "null"] },
        "compliance_owner": { "type": ["string", "null"] },
        "decision_owner": { "type": ["string", "null"] }
      }
    },
    "business_context": {
      "type": "object",
      "required": ["user_scenario", "pain_evidence", "target_outcome"],
      "properties": {
        "user_scenario": {
          "type": "object",
          "properties": {
            "user_role": { "type": ["string", "null"] },
            "customer_type": { "type": ["string", "null"] },
            "business_scene": { "type": ["string", "null"] },
            "current_workflow": { "type": ["string", "null"] },
            "target_workflow": { "type": ["string", "null"] }
          }
        },
        "pain_evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "source": { "type": ["string", "null"] },
              "evidence": { "type": ["string", "null"] },
              "date": { "type": ["string", "null"] }
            }
          }
        },
        "target_outcome": {
          "type": "object",
          "properties": {
            "user_success_result": { "type": ["string", "null"] },
            "business_result": { "type": ["string", "null"] },
            "measurable_kpi": { "type": "array" }
          }
        },
        "buyer_chain": { "type": "object" }
      }
    },
    "commercial_context": {
      "type": "object",
      "required": [
        "customer_segment",
        "pack_level",
        "l2_scenario",
        "l3_aggregation_logic",
        "target_buyer",
        "target_user",
        "customer_pain",
        "current_alternative",
        "evidence",
        "deliverable",
        "why_customer_will_pay",
        "market_or_customer_pool",
        "design_partners",
        "poc_path",
        "cooperation_model",
        "pricing_hypothesis",
        "biggest_delivery_risk",
        "next_sales_action",
        "pmf_confidence"
      ],
      "properties": {
        "customer_segment": {
          "type": "string",
          "enum": ["KA", "SMB", "hybrid", "internal", "unknown", "not_applicable"]
        },
        "pack_level": {
          "type": "string",
          "enum": ["L2", "L3", "L2_to_L3", "unknown", "not_applicable"]
        },
        "l2_scenario": { "type": ["string", "null"] },
        "l3_aggregation_logic": { "type": ["string", "null"] },
        "target_buyer": { "type": ["string", "null"] },
        "target_user": { "type": ["string", "null"] },
        "customer_pain": { "type": ["string", "null"] },
        "current_alternative": { "type": ["string", "null"] },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "description", "source_link"],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "customer_meeting",
                  "sales_lead",
                  "paid_poc",
                  "internal_observation",
                  "customer_quote",
                  "usage_data",
                  "other",
                  "unknown"
                ]
              },
              "description": { "type": ["string", "null"] },
              "source_link": { "type": ["string", "null"] }
            }
          }
        },
        "deliverable": { "type": ["string", "null"] },
        "why_customer_will_pay": { "type": ["string", "null"] },
        "market_or_customer_pool": { "type": ["string", "null"] },
        "design_partners": { "type": "array" },
        "poc_path": { "type": ["string", "null"] },
        "cooperation_model": { "type": ["string", "null"] },
        "pricing_hypothesis": { "type": ["string", "null"] },
        "biggest_delivery_risk": { "type": ["string", "null"] },
        "next_sales_action": { "type": ["string", "null"] },
        "pmf_confidence": {
          "type": "string",
          "enum": ["high", "medium", "low", "unknown", "not_applicable"]
        }
      }
    },
    "business_objects": {
      "type": "object",
      "required": [
        "durable_assets",
        "generated_artifacts",
        "temporary_artifacts",
        "future_reusable_assets"
      ],
      "properties": {
        "durable_assets": { "type": "array" },
        "generated_artifacts": { "type": "array" },
        "temporary_artifacts": { "type": "array" },
        "future_reusable_assets": { "type": "array" }
      }
    },
    "spec_decomposition": {
      "type": "object",
      "properties": {
        "current_spec_choice": { "type": "string" },
        "why_not_split_now": { "type": ["string", "null"] },
        "recommended_followups": { "type": "array" }
      }
    },
    "scope": {
      "type": "object",
      "required": [
        "in_scope",
        "out_of_scope",
        "non_goals",
        "delivery_boundary",
        "assumptions",
        "open_questions"
      ],
      "properties": {
        "in_scope": { "type": "array" },
        "out_of_scope": { "type": "array" },
        "non_goals": { "type": "array" },
        "delivery_boundary": { "type": ["string", "null"] },
        "assumptions": { "type": "array" },
        "open_questions": { "type": "array" }
      }
    },
    "input_materials": {
      "type": "object",
      "required": [
        "durable_sources",
        "per_case_inputs",
        "temporary_sources",
        "excluded_inputs",
        "update_frequency"
      ],
      "properties": {
        "durable_sources": { "type": "array" },
        "per_case_inputs": { "type": "array" },
        "temporary_sources": { "type": "array" },
        "excluded_inputs": { "type": "array" },
        "update_frequency": { "type": ["string", "null"] }
      }
    },
    "workflow": {
      "type": "object",
      "required": ["phases", "steps", "roles"],
      "properties": {
        "phases": { "type": "array" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "step_id",
              "phase",
              "actor",
              "input",
              "action",
              "output",
              "human_review_required",
              "failure_handling"
            ],
            "properties": {
              "step_id": { "type": "string" },
              "phase": { "type": "string" },
              "actor": { "type": "string" },
              "input": { "type": ["string", "array", "object", "null"] },
              "action": { "type": "string" },
              "output": { "type": ["string", "array", "object", "null"] },
              "human_review_required": { "type": "boolean" },
              "failure_handling": { "type": ["string", "null"] }
            }
          }
        },
        "roles": { "type": "array" }
      }
    },
    "domain_pack_context": {
      "type": "object",
      "required": [
        "applicable",
        "pack_definition",
        "target_industry_or_scene",
        "pack_goal",
        "commercial_or_delivery_unit",
        "domain_workflow",
        "memory_assets",
        "recipe_assets",
        "connector_assets",
        "interface_configuration",
        "permission_scope",
        "non_memory_boundaries",
        "workspace_instance_policy",
        "first_recipe",
        "iteration_loop",
        "self_learning_policy",
        "versioning_policy",
        "evaluation_assets",
        "marketplace_or_delivery",
        "workspace_design"
      ],
      "properties": {
        "applicable": { "type": "boolean" },
        "pack_definition": { "type": ["string", "null"] },
        "target_industry_or_scene": { "type": ["string", "null"] },
        "pack_goal": { "type": ["string", "null"] },
        "commercial_or_delivery_unit": {
          "type": "string",
          "enum": [
            "marketplace_pack",
            "ka_poc_pack",
            "smb_pack",
            "private_deployment_pack",
            "internal_pack",
            "demo_pack",
            "unknown",
            "not_applicable"
          ]
        },
        "domain_workflow": { "type": ["string", "null"] },
        "memory_assets": { "type": "array" },
        "recipe_assets": { "type": "array" },
        "connector_assets": { "type": "array" },
        "interface_configuration": { "type": "array" },
        "permission_scope": { "type": "array" },
        "non_memory_boundaries": { "type": "array" },
        "workspace_instance_policy": {
          "type": "object",
          "required": [
            "workspace_created_by",
            "workspace_lifecycle",
            "room_granularity",
            "artifact_types",
            "local_changes_policy",
            "master_pack_update_policy"
          ],
          "properties": {
            "workspace_created_by": { "type": ["string", "null"] },
            "workspace_lifecycle": { "type": "array" },
            "room_granularity": { "type": ["string", "null"] },
            "artifact_types": { "type": "array" },
            "local_changes_policy": { "type": "array" },
            "master_pack_update_policy": { "type": "array" }
          }
        },
        "first_recipe": {
          "type": "object",
          "required": [
            "name",
            "goal",
            "input",
            "output",
            "execution_logic",
            "constraints",
            "required_evidence",
            "human_review",
            "owner"
          ],
          "properties": {
            "name": { "type": ["string", "null"] },
            "goal": { "type": ["string", "null"] },
            "input": { "type": "array" },
            "output": { "type": "array" },
            "execution_logic": { "type": "array" },
            "constraints": { "type": "array" },
            "required_evidence": { "type": "array" },
            "human_review": { "type": "array" },
            "owner": { "type": ["string", "null"] }
          }
        },
        "iteration_loop": { "type": "array" },
        "self_learning_policy": { "type": "array" },
        "versioning_policy": {
          "type": "object",
          "required": [
            "domain_pack_versioned",
            "recipe_versioned",
            "workspace_versioned",
            "memory_backup_or_rollback",
            "release_policy",
            "upgrade_policy",
            "rollback_policy"
          ],
          "properties": {
            "domain_pack_versioned": { "type": "boolean" },
            "recipe_versioned": { "type": "boolean" },
            "workspace_versioned": { "type": "boolean" },
            "memory_backup_or_rollback": { "type": "array" },
            "release_policy": { "type": "array" },
            "upgrade_policy": { "type": "array" },
            "rollback_policy": { "type": "array" }
          }
        },
        "evaluation_assets": {
          "type": "object",
          "required": [
            "golden_tasks",
            "rubrics",
            "failure_cases",
            "acceptance_checklist",
            "regression_set"
          ],
          "properties": {
            "golden_tasks": { "type": "array" },
            "rubrics": { "type": "array" },
            "failure_cases": { "type": "array" },
            "acceptance_checklist": { "type": "array" },
            "regression_set": { "type": "array" }
          }
        },
        "marketplace_or_delivery": {
          "type": "object",
          "required": [
            "offer_name",
            "target_buyers_or_users",
            "pricing_or_packaging_notes",
            "deployment_notes",
            "success_metrics"
          ],
          "properties": {
            "offer_name": { "type": ["string", "null"] },
            "target_buyers_or_users": { "type": "array" },
            "pricing_or_packaging_notes": { "type": "array" },
            "deployment_notes": { "type": "array" },
            "success_metrics": { "type": "array" }
          }
        },
        "workspace_design": {
          "type": "object",
          "required": [
            "screens",
            "artifacts",
            "controls",
            "open_questions"
          ],
          "properties": {
            "screens": { "type": "array" },
            "artifacts": { "type": "array" },
            "controls": { "type": "array" },
            "open_questions": { "type": "array" }
          }
        }
      }
    },
    "priority_decision": {
      "type": "object",
      "required": [
        "candidate_rank",
        "recommendation",
        "reason",
        "missing_evidence",
        "decision_owner"
      ],
      "properties": {
        "candidate_rank": { "type": ["integer", "null"] },
        "recommendation": {
          "type": "string",
          "enum": [
            "top_8",
            "backlog",
            "reject",
            "needs_more_evidence",
            "not_applicable",
            "unknown"
          ]
        },
        "reason": { "type": ["string", "null"] },
        "missing_evidence": { "type": "array" },
        "decision_owner": { "type": ["string", "null"] }
      }
    },
    "ui_requirements": {
      "type": "object",
      "required": [
        "has_ui",
        "wireframe_required",
        "wireframe_status",
        "key_screens",
        "wireframe_artifacts",
        "confirmation_method",
        "open_questions"
      ],
      "properties": {
        "has_ui": { "type": "boolean" },
        "wireframe_required": { "type": "boolean" },
        "wireframe_status": {
          "type": "string",
          "enum": ["not_required", "needed", "drafted", "reviewed", "unknown"]
        },
        "key_screens": { "type": "array" },
        "wireframe_artifacts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confirmation_method": { "type": ["string", "null"] },
        "open_questions": { "type": "array" }
      }
    },
    "capability_boundaries": {
      "type": "object",
      "required": [
        "memory_layer",
        "agent_or_recipe_layer",
        "product_ui_layer",
        "external_business_systems",
        "human_or_compliance_review",
        "explicitly_not_owned"
      ],
      "properties": {
        "memory_layer": { "type": "array" },
        "agent_or_recipe_layer": { "type": "array" },
        "product_ui_layer": { "type": "array" },
        "external_business_systems": { "type": "array" },
        "human_or_compliance_review": { "type": "array" },
        "explicitly_not_owned": { "type": "array" }
      }
    },
    "evidence_requirements": {
      "type": "object",
      "required": [
        "must_trace",
        "source_granularity",
        "unknown_or_uncertain_handling"
      ],
      "properties": {
        "must_trace": { "type": "array" },
        "source_granularity": { "type": "array" },
        "unknown_or_uncertain_handling": { "type": "array" }
      }
    },
    "data_governance": {
      "type": "object",
      "required": [
        "sensitivity",
        "permission_model",
        "versioning",
        "retention",
        "audit_log"
      ],
      "properties": {
        "sensitivity": { "type": "array" },
        "permission_model": { "type": "array" },
        "versioning": { "type": "array" },
        "retention": { "type": "array" },
        "audit_log": { "type": "array" }
      }
    },
    "product_requirements": { "type": "object" },
    "technical_requirements": { "type": "object" },
    "acceptance_standards": { "type": "object" },
    "poc_metrics": { "type": "object" },
    "testing_standards": { "type": "object" },
    "operation_standards": { "type": "object" },
    "commercial_standards": { "type": "object" },
    "reuse_standards": { "type": "object" },
    "story_points": { "type": "object" },
    "review_gates": { "type": "object" },
    "missing_fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "status", "note"],
        "properties": {
          "field": { "type": "string" },
          "status": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "decision_log": { "type": "array" },
    "change_log": { "type": "array" },
    "readiness_label": {
      "type": "string",
      "enum": ["not_ready", "business_ready", "product_ready", "engineering_ready", "review_required"]
    }
  }
}
