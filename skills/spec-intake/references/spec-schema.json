{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spec Driven Intake Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "spec_id",
    "title",
    "status",
    "priority",
    "stage_gate",
    "opportunity_assessment",
    "product_context",
    "owners",
    "business_context",
    "scope",
    "workflow",
    "friday_object_model",
    "knowledge_and_memory_policy",
    "ui_requirements",
    "capability_boundaries",
    "validation_plan",
    "operation_standards",
    "implementation_mapping",
    "review_gates",
    "missing_fields"
  ],
  "properties": {
    "spec_version": { "type": "string" },
    "spec_id": { "type": "string" },
    "title": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "spec_review",
        "poc_design",
        "poc_execution",
        "ready_for_engineering",
        "in_development",
        "qa_gate",
        "business_acceptance",
        "launched",
        "rejected",
        "archived"
      ]
    },
    "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "unknown"] },
    "stage_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_stage",
        "readiness_label",
        "decision",
        "allowed_next_actions",
        "blocked_next_actions",
        "blockers",
        "required_owner",
        "stage_exit_check"
      ],
      "properties": {
        "current_stage": {
          "type": "string",
          "enum": [
            "business_feasibility",
            "product_shape",
            "engineering_gap_review",
            "technical_spec",
            "poc_design",
            "poc_execution",
            "engineering_delivery",
            "stop_archive",
            "unknown"
          ]
        },
        "readiness_label": {
          "type": "string",
          "enum": [
            "not_ready",
            "business_ready",
            "product_ready",
            "engineering_gap_review_ready",
            "poc_design_ready",
            "poc_execution_ready",
            "engineering_ready",
            "review_required"
          ]
        },
        "decision": {
          "type": "string",
          "enum": [
            "continue_business_validation",
            "handoff_to_product",
            "continue_product_shape",
            "request_engineering_gap_review",
            "continue_technical_spec",
            "mark_poc_design_ready",
            "mark_poc_execution_ready",
            "ready_for_engineering",
            "stop_archive",
            "unknown"
          ]
        },
        "allowed_next_actions": { "type": "array", "items": { "type": "string" } },
        "blocked_next_actions": { "type": "array", "items": { "type": "string" } },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "required_owner": { "type": ["string", "null"] },
        "stage_exit_check": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "exit_summary",
            "confirmation_question",
            "confirmed_by",
            "confirmed_at",
            "next_stage"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["not_started", "ready_for_confirmation", "confirmed", "rejected", "not_applicable"]
            },
            "exit_summary": { "type": ["string", "null"] },
            "confirmation_question": { "type": ["string", "null"] },
            "confirmed_by": { "type": ["string", "null"] },
            "confirmed_at": { "type": ["string", "null"] },
            "next_stage": { "type": ["string", "null"] }
          }
        }
      }
    },
    "opportunity_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commercial_context",
        "pmf_validation",
        "priority_decision",
        "competitive_research",
        "evidence_registry",
        "design_partner_registry",
        "minimum_paid_artifact"
      ],
      "properties": {
        "commercial_context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "customer_segment",
            "pack_level",
            "l2_scenario",
            "l3_aggregation_logic",
            "target_buyer",
            "market_or_customer_pool",
            "why_customer_will_pay",
            "poc_path",
            "cooperation_model",
            "pricing_hypothesis",
            "biggest_delivery_risk",
            "next_sales_action",
            "pmf_confidence"
          ],
          "properties": {
            "customer_segment": {
              "type": "string",
              "enum": ["KA", "SMB", "hybrid", "internal", "unknown", "not_applicable"]
            },
            "pack_level": {
              "type": "string",
              "enum": ["L2", "L3", "L2_to_L3", "unknown", "not_applicable"]
            },
            "l2_scenario": { "type": ["string", "null"] },
            "l3_aggregation_logic": { "type": ["string", "null"] },
            "target_buyer": { "type": ["string", "null"] },
            "market_or_customer_pool": { "type": ["string", "null"] },
            "why_customer_will_pay": { "type": ["string", "null"] },
            "poc_path": { "type": ["string", "null"] },
            "cooperation_model": { "type": ["string", "null"] },
            "pricing_hypothesis": { "type": ["string", "null"] },
            "biggest_delivery_risk": { "type": ["string", "null"] },
            "next_sales_action": { "type": ["string", "null"] },
            "pmf_confidence": {
              "type": "string",
              "enum": ["high", "medium", "low", "unknown", "not_applicable"]
            }
          }
        },
        "pmf_validation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "use_case_id",
            "source_entry",
            "current_state",
            "target_icp",
            "workflow",
            "pain_evidence_refs",
            "current_alternative",
            "buyer_language",
            "competitive_gap",
            "decision_chain",
            "paid_signal",
            "four_factor_scores",
            "overall_decision",
            "next_action",
            "owner",
            "poc_entry_criteria"
          ],
          "properties": {
            "use_case_id": { "type": ["string", "null"] },
            "source_entry": {
              "type": "string",
              "enum": ["销售线索池", "市场/客户线索池", "internal", "unknown", "not_applicable"]
            },
            "current_state": {
              "type": "string",
              "enum": [
                "销售线索池",
                "场景归类",
                "痛点诊断",
                "产研评估",
                "PoC / GTM 实验",
                "复盘判定",
                "主线 / 停损",
                "unknown",
                "not_applicable"
              ]
            },
            "target_icp": { "type": ["string", "null"] },
            "workflow": { "type": ["string", "null"] },
            "pain_evidence_refs": { "type": "array", "items": { "type": "string" } },
            "current_alternative": { "type": ["string", "null"] },
            "buyer_language": { "type": ["string", "null"] },
            "competitive_gap": { "type": ["string", "null"] },
            "decision_chain": { "type": ["string", "null"] },
            "paid_signal": { "type": ["string", "null"] },
            "four_factor_scores": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "customer_willingness",
                "market_clarity",
                "technical_value",
                "gtm_repeatability"
              ],
              "properties": {
                "customer_willingness": { "$ref": "#/$defs/pmf_score" },
                "market_clarity": { "$ref": "#/$defs/pmf_score" },
                "technical_value": { "$ref": "#/$defs/pmf_score" },
                "gtm_repeatability": { "$ref": "#/$defs/pmf_score" }
              }
            },
            "overall_decision": {
              "type": "string",
              "enum": ["继续诊断", "进入产研评估", "批准 PoC", "主线候选", "停止/归档", "unknown", "not_applicable"]
            },
            "next_action": { "type": ["string", "null"] },
            "owner": { "type": ["string", "null"] },
            "poc_entry_criteria": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "customer_evidence",
                "paid_signal",
                "data_available",
                "baseline_defined",
                "acceptance_method",
                "timebox_and_resource_cap"
              ],
              "properties": {
                "customer_evidence": { "type": ["string", "null"] },
                "paid_signal": { "type": ["string", "null"] },
                "data_available": { "type": ["string", "null"] },
                "baseline_defined": { "type": ["string", "null"] },
                "acceptance_method": { "type": ["string", "null"] },
                "timebox_and_resource_cap": { "type": ["string", "null"] }
              }
            }
          }
        },
        "priority_decision": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "candidate_rank",
            "recommendation",
            "business_value_score",
            "commercial_signal_clarity_score",
            "product_engineering_effort_score",
            "opportunity_priority_score",
            "formula_name",
            "formula",
            "scope_expansion_risk",
            "scope_reduction_recommendation",
            "reason",
            "missing_evidence",
            "decision_owner"
          ],
          "properties": {
            "candidate_rank": { "type": ["integer", "null"] },
            "recommendation": {
              "type": "string",
              "enum": ["top_8", "backlog", "reject", "needs_more_evidence", "not_applicable", "unknown"]
            },
            "business_value_score": { "type": ["number", "null"] },
            "commercial_signal_clarity_score": { "type": ["number", "null"] },
            "product_engineering_effort_score": { "type": ["number", "null"] },
            "opportunity_priority_score": { "type": ["number", "null"] },
            "formula_name": { "type": "string", "enum": ["机会优先级指数"] },
            "formula": {
              "type": "string",
              "enum": ["机会优先级指数 = 商业价值 * 商业信号清晰度 / 产研投入量"]
            },
            "scope_expansion_risk": {
              "type": "string",
              "enum": ["high", "medium", "low", "unknown", "not_applicable"]
            },
            "scope_reduction_recommendation": { "type": ["string", "null"] },
            "reason": { "type": ["string", "null"] },
            "missing_evidence": { "type": "array", "items": { "type": "string" } },
            "decision_owner": { "type": ["string", "null"] }
          }
        },
        "competitive_research": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "user_provided",
            "research_required",
            "research_queries",
            "comparison_matrix",
            "differentiation_score",
            "user_confirmation"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["not_started", "user_provided", "agent_researched", "confirmed", "not_applicable"]
            },
            "user_provided": { "type": "boolean" },
            "research_required": { "type": "boolean" },
            "research_queries": { "type": "array", "items": { "type": "string" } },
            "comparison_matrix": {
              "type": "array",
              "items": { "$ref": "#/$defs/competitor_comparison" }
            },
            "differentiation_score": {
              "type": "object",
              "additionalProperties": false,
              "required": ["score", "rationale", "scoring_method"],
              "properties": {
                "score": { "type": ["number", "null"] },
                "rationale": { "type": ["string", "null"] },
                "scoring_method": { "type": ["string", "null"] }
              }
            },
            "user_confirmation": {
              "type": "string",
              "enum": ["pending", "confirmed", "rejected", "not_required", "unknown"]
            }
          }
        },
        "evidence_registry": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_item" }
        },
        "design_partner_registry": {
          "type": "array",
          "items": { "$ref": "#/$defs/design_partner" }
        },
        "minimum_paid_artifact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "description", "buyer_value", "not_included"],
          "properties": {
            "name": { "type": ["string", "null"] },
            "description": { "type": ["string", "null"] },
            "buyer_value": { "type": ["string", "null"] },
            "not_included": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "product_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "build_target",
        "spec_type",
        "company_product",
        "product_assumptions",
        "technical_leadership",
        "product_open_questions"
      ],
      "properties": {
        "build_target": {
          "type": "string",
          "enum": [
            "friday_agent",
            "domain_pack",
            "friday_memory",
            "morningstar",
            "internal_tool",
            "standalone_product",
            "demo",
            "unknown"
          ]
        },
        "spec_type": {
          "type": "string",
          "enum": [
            "customer_poc",
            "domain_pack",
            "product_feature",
            "internal_tool",
            "data_project",
            "automation",
            "platform_capability"
          ]
        },
        "company_product": { "type": ["string", "null"] },
        "product_assumptions": { "type": "array", "items": { "type": "string" } },
        "technical_leadership": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "claim",
            "proof_or_argument",
            "evidence_refs",
            "spec_agent_score",
            "score_rationale",
            "product_owner_confirmation"
          ],
          "properties": {
            "claim": { "type": ["string", "null"] },
            "proof_or_argument": { "type": ["string", "null"] },
            "evidence_refs": { "type": "array", "items": { "type": "string" } },
            "spec_agent_score": { "type": ["number", "null"] },
            "score_rationale": { "type": ["string", "null"] },
            "product_owner_confirmation": {
              "type": "string",
              "enum": ["pending", "confirmed", "rejected", "not_required", "unknown"]
            }
          }
        },
        "product_open_questions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "product_line": { "type": ["string", "null"] },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "owners": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "business_owner",
        "product_owner",
        "engineering_owner",
        "qa_owner",
        "devops_owner",
        "compliance_owner",
        "decision_owner"
      ],
      "properties": {
        "business_owner": { "type": ["string", "null"] },
        "product_owner": { "type": ["string", "null"] },
        "engineering_owner": { "type": ["string", "null"] },
        "qa_owner": { "type": ["string", "null"] },
        "devops_owner": { "type": ["string", "null"] },
        "compliance_owner": { "type": ["string", "null"] },
        "decision_owner": { "type": ["string", "null"] }
      }
    },
    "business_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user_scenario", "target_outcome"],
      "properties": {
        "user_scenario": { "$ref": "#/$defs/user_scenario" },
        "target_outcome": { "$ref": "#/$defs/target_outcome" }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in_scope", "out_of_scope", "non_goals", "delivery_boundary", "assumptions", "open_questions"],
      "properties": {
        "in_scope": { "type": "array", "items": { "type": "string" } },
        "out_of_scope": { "type": "array", "items": { "type": "string" } },
        "non_goals": { "type": "array", "items": { "type": "string" } },
        "delivery_boundary": { "type": ["string", "null"] },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "open_questions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonical_workflow", "phases", "steps", "roles"],
      "properties": {
        "canonical_workflow": { "type": ["string", "null"] },
        "phases": { "type": "array", "items": { "type": "string" } },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/workflow_step" }
        },
        "roles": { "type": "array", "items": { "type": "string" } }
      }
    },
    "friday_object_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_memory",
        "tasks",
        "artifacts",
        "recipes",
        "feedback_comments",
        "rooms",
        "object_relationships"
      ],
      "properties": {
        "workspace_memory": { "type": "array", "items": { "$ref": "#/$defs/friday_object" } },
        "tasks": { "type": "array", "items": { "$ref": "#/$defs/friday_object" } },
        "artifacts": { "type": "array", "items": { "$ref": "#/$defs/friday_object" } },
        "recipes": { "type": "array", "items": { "$ref": "#/$defs/friday_object" } },
        "feedback_comments": { "type": "array", "items": { "$ref": "#/$defs/friday_object" } },
        "rooms": { "type": "array", "items": { "$ref": "#/$defs/friday_object" } },
        "object_relationships": { "type": "array", "items": { "type": "string" } }
      }
    },
    "knowledge_and_memory_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_materials",
        "source_traceability",
        "memory_write_rules",
        "non_memory_boundaries",
        "privacy_and_redaction",
        "rollback_policy"
      ],
      "properties": {
        "input_materials": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "durable_sources",
            "per_case_inputs",
            "temporary_sources",
            "excluded_inputs",
            "update_frequency"
          ],
          "properties": {
            "durable_sources": { "type": "array", "items": { "type": "string" } },
            "per_case_inputs": { "type": "array", "items": { "type": "string" } },
            "temporary_sources": { "type": "array", "items": { "type": "string" } },
            "excluded_inputs": { "type": "array", "items": { "type": "string" } },
            "update_frequency": { "type": ["string", "null"] }
          }
        },
        "source_traceability": { "type": "array", "items": { "type": "string" } },
        "memory_write_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/memory_write_rule" }
        },
        "non_memory_boundaries": { "type": "array", "items": { "type": "string" } },
        "privacy_and_redaction": { "type": "array", "items": { "type": "string" } },
        "rollback_policy": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ui_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "has_ui",
        "wireframe_required",
        "wireframe_status",
        "key_screens",
        "wireframe_artifacts",
        "confirmation_method",
        "open_questions"
      ],
      "properties": {
        "has_ui": { "type": "boolean" },
        "wireframe_required": { "type": "boolean" },
        "wireframe_status": {
          "type": "string",
          "enum": ["not_required", "needed", "drafted", "reviewed", "unknown"]
        },
        "key_screens": { "type": "array", "items": { "type": "string" } },
        "wireframe_artifacts": { "type": "array", "items": { "type": "string" } },
        "confirmation_method": { "type": ["string", "null"] },
        "open_questions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "capability_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory_layer",
        "agent_or_recipe_layer",
        "product_ui_layer",
        "external_business_systems",
        "human_or_compliance_review",
        "explicitly_not_owned"
      ],
      "properties": {
        "memory_layer": { "type": "array", "items": { "type": "string" } },
        "agent_or_recipe_layer": { "type": "array", "items": { "type": "string" } },
        "product_ui_layer": { "type": "array", "items": { "type": "string" } },
        "external_business_systems": { "type": "array", "items": { "type": "string" } },
        "human_or_compliance_review": { "type": "array", "items": { "type": "string" } },
        "explicitly_not_owned": { "type": "array", "items": { "type": "string" } }
      }
    },
    "validation_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "business_acceptance",
        "product_acceptance",
        "poc_design_ready",
        "poc_execution_ready",
        "metrics",
        "evaluation_assets"
      ],
      "properties": {
        "business_acceptance": { "type": "array", "items": { "type": "string" } },
        "product_acceptance": { "type": "array", "items": { "type": "string" } },
        "poc_design_ready": { "$ref": "#/$defs/readiness_check" },
        "poc_execution_ready": { "$ref": "#/$defs/readiness_check" },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/metric" }
        },
        "evaluation_assets": {
          "type": "array",
          "items": { "$ref": "#/$defs/evaluation_asset" }
        }
      }
    },
    "operation_standards": {
      "type": "object",
      "additionalProperties": false,
      "required": ["monitoring", "fallback", "support", "audit_events"],
      "properties": {
        "monitoring": { "type": "array", "items": { "type": "string" } },
        "fallback": { "type": "array", "items": { "type": "string" } },
        "support": { "type": "array", "items": { "type": "string" } },
        "audit_events": { "type": "array", "items": { "type": "string" } }
      }
    },
    "implementation_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engineering_review_type",
        "capabilities",
        "source_code_review",
        "technical_design_assessment"
      ],
      "properties": {
        "engineering_review_type": {
          "type": "string",
          "enum": ["not_started", "engineering_gap_review", "technical_design", "delivery_plan", "unknown"]
        },
        "capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/implementation_capability" }
        },
        "source_code_review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "status", "paths_read", "summary", "unread_required_paths"],
          "properties": {
            "required": { "type": "boolean" },
            "status": {
              "type": "string",
              "enum": ["not_required", "not_started", "partial", "completed", "blocked"]
            },
            "paths_read": { "type": "array", "items": { "type": "string" } },
            "summary": { "type": ["string", "null"] },
            "unread_required_paths": { "type": "array", "items": { "type": "string" } }
          }
        },
        "technical_design_assessment": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "design_summary",
            "ai_score",
            "scoring_dimensions",
            "score_rationale",
            "ai_engineer_confirmation"
          ],
          "properties": {
            "design_summary": { "type": ["string", "null"] },
